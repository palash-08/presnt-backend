# ─── Environment ──────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://presnt_user:YOUR_DB_PASSWORD@localhost:5432/presnt_db

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_HEX_STRING

# Server port
PORT=3001

# ─── Google OAuth ─────────────────────────────────────────────────
# Web Client ID from Google Cloud Console (same one used in the mobile app)
GOOGLE_CLIENT_ID=1013351571460-1agh2ggtdocijtnv3ueba7lc80v9ce1i.apps.googleusercontent.com

# ─── Email (Gmail App Password) ──────────────────────────────────
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Create an app password for "Mail"
# 3. Paste the 16-character password below
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# ─── CORS ─────────────────────────────────────────────────────────
# Not needed for mobile apps! CORS is a browser-only restriction.
# The server already allows all origins with cors({ origin: '*' }).
# If you ever build a web dashboard, add its URL here.
