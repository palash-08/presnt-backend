// ─── Prisma Schema ──────────────────────────────────────────────────────────
// This defines the PostgreSQL database structure for the Presnt app.
// Run `npx prisma migrate dev` to create/update tables.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ──────────────────────────────────────────────────────────────────
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String?  // null for Google-only users
  name          String
  role          String   @default("student") // "admin" | "teacher" | "student"
  rollNumber    String?
  googleId      String?  @unique
  expoPushToken String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  groupMembers      GroupMember[]
  attendanceRecords AttendanceRecord[]
  attendanceHistory AttendanceHistory[]
  notifications     Notification[]
}

// ─── Groups ─────────────────────────────────────────────────────────────────
model Group {
  id         String   @id @default(cuid()) // short, human-readable invite code
  name       String
  creatorId  String
  isPersonal Boolean  @default(false)
  createdAt  DateTime @default(now())

  members   GroupMember[]
  subjects  Subject[]
  schedules Schedule[]
}

// ─── Group Members (join table) ─────────────────────────────────────────────
model GroupMember {
  id      String @id @default(uuid())
  userId  String
  groupId String
  role    String @default("Student") // "Admin" | "Co-Admin" | "Teacher" | "Student"

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

// ─── Subjects ───────────────────────────────────────────────────────────────
model Subject {
  id           String   @id @default(uuid())
  groupId      String
  name         String
  code         String?
  credits      Int      @default(3)
  totalClasses Int      @default(0)
  classDates   String[] @default([]) // e.g. ["2026-06-18", "2026-06-18_slotId"]
  createdAt    DateTime @default(now())

  group             Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  schedules         Schedule[]
  attendanceRecords AttendanceRecord[]
  attendanceHistory AttendanceHistory[]
}

// ─── Schedule ───────────────────────────────────────────────────────────────
model Schedule {
  id          String   @id @default(uuid())
  groupId     String
  subjectId   String
  subjectName String
  subjectCode String?
  dayOfWeek   String   // "Monday", "Tuesday", etc.
  time        String   // "09:00 AM"
  room        String   @default("N/A")
  createdAt   DateTime @default(now())

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}

// ─── Attendance Records (per-user, per-subject summary) ─────────────────────
model AttendanceRecord {
  id          String   @id @default(uuid())
  userId      String
  subjectId   String
  subjectName String
  subjectCode String?
  attended    Int      @default(0)
  total       Int      @default(0)
  updatedAt   DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId])
}

// ─── Attendance History (per-user, per-subject, per-date detail) ────────────
model AttendanceHistory {
  id        String   @id @default(uuid())
  userId    String
  subjectId String
  date      DateTime // the class date
  slotId    String?  // schedule slot ID (nullable)
  slotTime  String?  // "09:00 AM" (nullable)
  present   Boolean  @default(true)
  dateKey   String   // "2026-06-18" or "2026-06-18_slotId" — for uniqueness
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([userId, subjectId, dateKey])
}

// ─── Notifications ──────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  data      Json     @default("{}")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
